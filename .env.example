# ─── Server ───────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# ─── PostgreSQL ───────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=changeme
DB_NAME=ai_service_platform

# ─── Redis ────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── AI Providers ────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
PRIMARY_PROVIDER=anthropic
SECONDARY_PROVIDER=openai

# ─── Billing Splits (percentages, must sum to 100) ──────
BILLING_OWNER_SPLIT_PCT=5
BILLING_IMPROVEMENT_SPLIT_PCT=50
BILLING_COMPUTE_SPLIT_PCT=30
BILLING_RESERVE_SPLIT_PCT=15
BILLING_OWNER_PAYOUT_THRESHOLD_CENTS=10000
BILLING_MIN_IMPROVEMENT_FUND_CENTS=20000

# ─── Stripe ──────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Domain ──────────────────────────────────────────────
DOMAIN=localhost
