{
  "name": "ai-service-platform",
  "version": "0.1.0",
  "description": "Autonomous AI-to-AI service platform — sells intelligence to other AI systems via MCP and REST API",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "start:worker": "node dist/worker.js",
    "migrate": "tsx src/db/migrate.ts",
    "seed": "tsx seeds/default-services.ts",
    "test": "node --import tsx --test tests/billing/revenue-split.test.ts tests/billing/discounts.test.ts tests/billing/engine.test.ts tests/api/health.test.ts tests/services/model-router.test.ts tests/providers/cost-tracker.test.ts tests/mcp/tools.test.ts",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "generate:openapi": "tsx scripts/generate-openapi.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "bullmq": "^5.34.0",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "fastify-plugin": "^5.0.1",
    "@fastify/cors": "^10.0.2",
    "@fastify/rate-limit": "^10.2.1",
    "@fastify/swagger": "^9.4.2",
    "@fastify/swagger-ui": "^5.2.1",
    "ioredis": "^5.4.2",
    "openai": "^4.81.0",
    "pg": "^8.13.1",
    "pgvector": "^0.2.0",
    "pino": "^9.6.0",
    "stripe": "^17.5.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
